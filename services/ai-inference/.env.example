# AI Inference service — standalone (non-Docker) environment template.
# In Docker these values are injected by docker-compose.yml.

LOG_LEVEL=debug

# Point at localhost when running outside Compose.
DATABASE_URL=postgresql://facevec:facevec@localhost:5432/facevec
RABBITMQ_URL=amqp://facevec:facevec@localhost:5672

# Cosine-similarity acceptance threshold for identification (0..1).
FACE_MATCH_THRESHOLD=0.75

# InsightFace model pack + execution provider (used from Phase 4).
INSIGHTFACE_MODEL=buffalo_l
ONNX_EXECUTION_PROVIDER=CPUExecutionProvider
