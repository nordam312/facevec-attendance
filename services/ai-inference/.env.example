# AI Inference service — standalone (non-Docker) environment template.
# In Docker these values are injected by docker-compose.yml.
#
# This service is STATELESS compute: it extracts face embeddings over HTTP and
# does not connect to Postgres or RabbitMQ (the gateway orchestrates those).

LOG_LEVEL=info

# InsightFace model pack and where its weights are cached on disk.
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_MODEL_ROOT=/models

# Detector input size (square, px) and confidence threshold (0..1).
FACE_DET_SIZE=640
FACE_DET_THRESH=0.5

# Reject uploads larger than this many bytes before decoding.
MAX_IMAGE_BYTES=10485760
