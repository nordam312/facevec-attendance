# API Gateway — standalone (non-Docker) environment template.
# In Docker these values are injected by docker-compose.yml.

NODE_ENV=development
LOG_LEVEL=debug
PORT=8080

# Connection strings (point at localhost when running outside Compose).
DATABASE_URL=postgresql://facevec:facevec@localhost:5432/facevec
REDIS_URL=redis://:facevec@localhost:6379
RABBITMQ_URL=amqp://facevec:facevec@localhost:5672
AI_INFERENCE_URL=http://localhost:8000

# Auth (generate with: openssl rand -hex 48)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# CORS allow-list (comma separated)
CORS_ORIGINS=http://localhost:3000

# Transactional-outbox relay (optional — sensible defaults shown).
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10

# AI inference client (optional).
AI_INFERENCE_TIMEOUT_MS=8000
MAX_UPLOAD_BYTES=10485760

# Redis-backed idempotency (optional). REDIS_URL above enables Redis features
# (idempotency, shared rate-limit, token revocation); all degrade if it is unset.
IDEMPOTENCY_TTL_SECONDS=86400

# Rate-limit budgets per minute, per IP (optional).
RATE_LIMIT_GLOBAL=120
RATE_LIMIT_AUTH=10

# Observability. /metrics is always on; tracing is enabled only when an OTLP/HTTP
# collector endpoint is set (e.g. http://localhost:4318). Leave empty to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=facevec-gateway

# Circuit breaker around the AI call (optional).
AI_BREAKER_TIMEOUT_MS=10000
AI_BREAKER_ERROR_THRESHOLD=50
AI_BREAKER_RESET_MS=15000
AI_BREAKER_VOLUME_THRESHOLD=3

# Async fallback queue (face_tasks) retry policy (optional).
FACE_TASK_PREFETCH=4
FACE_TASK_MAX_ATTEMPTS=5
FACE_TASK_RETRY_DELAY_MS=10000
