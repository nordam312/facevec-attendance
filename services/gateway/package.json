{
  "name": "@facevec/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "FaceVec API ingestion gateway (Express + TypeScript)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --watch --env-file-if-exists=.env --import tsx src/index.ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "eslint src",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node --env-file-if-exists=.env --import tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.1.0",
    "amqplib": "^0.10.9",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.0",
    "jose": "^5.9.6",
    "multer": "^2.1.1",
    "opossum": "^8.5.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prisma": "^6.1.0",
    "rate-limit-redis": "^4.3.1",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/amqplib": "^0.10.8",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.2",
    "@types/opossum": "^8.1.9",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
