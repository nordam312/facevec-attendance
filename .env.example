# =============================================================================
# Root environment template — consumed by docker-compose.yml for interpolation.
# Copy to `.env` (never commit `.env`) and replace every secret below.
#
#   cp .env.example .env
#
# Each service ALSO ships its own .env.example for running it standalone
# (outside Docker). This file only needs the values Compose wires together.
# =============================================================================

# ---- Deployment ----------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info

# ---- PostgreSQL + pgvector -----------------------------------------------
POSTGRES_USER=facevec
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=facevec
POSTGRES_PORT=5432

# ---- Redis ----------------------------------------------------------------
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_PORT=6379

# ---- RabbitMQ -------------------------------------------------------------
RABBITMQ_USER=facevec
RABBITMQ_PASSWORD=change-me-strong-rabbitmq-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ---- API Gateway (Express) -----------------------------------------------
GATEWAY_PORT=8080
# 64+ char random strings. Generate with: openssl rand -hex 48
JWT_ACCESS_SECRET=change-me-access-token-secret
JWT_REFRESH_SECRET=change-me-refresh-token-secret
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=1209600       # 14 days (seconds)
# Comma-separated list of origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000

# ---- AI Inference (FastAPI) ----------------------------------------------
AI_INFERENCE_PORT=8000
# Cosine-similarity acceptance threshold for identification (0..1).
FACE_MATCH_THRESHOLD=0.75

# ---- Web (Next.js) --------------------------------------------------------
WEB_PORT=3000
# Public base URL the browser uses to reach the gateway.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
